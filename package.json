{
  "name": "d7tun6-site-vite",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 127.0.0.1 --port 3001",
    "dev:api": "node server/index.mjs --dev",
    "generate:releases": "node scripts/generate-releases.mjs",
    "build": "npm run generate:releases && vite build",
    "start": "node server/index.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run lint && npm run typecheck && npm run build",
    "sanitize:check": "bash scripts/sanitize-for-github.sh --dry-run",
    "sanitize:github": "bash scripts/sanitize-for-github.sh --apply"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@mdx-js/react": "^3.1.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.4.2",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@mdx-js/rollup": "^3.1.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/node": "^25.3.3",
    "@types/express": "^5.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.1.12",
    "typescript": "^5.9.3"
  }
}
